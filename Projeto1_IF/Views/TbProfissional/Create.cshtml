@model Projeto1_IF.Models.TbProfissional

@{
    ViewData["Title"] = "Create";
}

<h1>Cadastrar</h1>

<h4>Profissional</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" id="formCadastroProfissional">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="IdContratoNavigation.IdPlano" class="control-label fw-semibold">Plano de Contrato</label>
                <select asp-for="IdContratoNavigation.IdPlano" class="form-control" asp-items="ViewBag.IdPlano">
                    <option value="">-- Selecione o Plano --</option>
                </select>
            </div>
            <div class="form-group">
                <label asp-for="IdCidade" class="control-label fw-semibold">Cidade</label>
                <select asp-for="IdCidade" class="form-control" asp-items="ViewBag.IdCidade">
                    <option value="">-- Selecione a Cidade --</option>
                </select>
                <span asp-validation-for="IdCidade" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Nome" class="control-label"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Cpf" class="control-label"></label>
                <input asp-for="Cpf" class="form-control" />
                <span asp-validation-for="Cpf" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CrmCrn" class="control-label"></label>
                <input asp-for="CrmCrn" class="form-control" />
                <span asp-validation-for="CrmCrn" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Logradouro" class="control-label"></label>
                <input asp-for="Logradouro" class="form-control" />
                <span asp-validation-for="Logradouro" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Numero" class="control-label"></label>
                <input asp-for="Numero" class="form-control" />
                <span asp-validation-for="Numero" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Bairro" class="control-label"></label>
                <input asp-for="Bairro" class="form-control" />
                <span asp-validation-for="Bairro" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Cep" class="control-label"></label>
                <input asp-for="Cep" class="form-control" />
                <span asp-validation-for="Cep" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Cidade" class="control-label"></label>
                <input asp-for="Cidade" class="form-control" />
                <span asp-validation-for="Cidade" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Estado" class="control-label"></label>
                <input asp-for="Estado" class="form-control" />
                <span asp-validation-for="Estado" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Ddd1" class="control-label"></label>
                <input asp-for="Ddd1" class="form-control" />
                <span asp-validation-for="Ddd1" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Ddd2" class="control-label"></label>
                <input asp-for="Ddd2" class="form-control" />
                <span asp-validation-for="Ddd2" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Telefone1" class="control-label"></label>
                <input asp-for="Telefone1" class="form-control" />
                <span asp-validation-for="Telefone1" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Telefone2" class="control-label"></label>
                <input asp-for="Telefone2" class="form-control" />
                <span asp-validation-for="Telefone2" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Salario" class="control-label"></label>
                <input asp-for="Salario" class="form-control" />
                <span asp-validation-for="Salario" class="text-danger"></span>
            </div>
        </form>
    </div>
</div>
<div class="d-flex gap-2 pt-3">
    <button type="submit" form="formCadastroProfissional" class="btn btn-primary">
        Cadastrar
    </button>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left-short"></i> Voltar
    </a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
