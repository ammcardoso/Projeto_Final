@model Projeto1_IF.Models.TbPaciente

@{
    ViewData["Title"] = "Details";
}

<h1>Detalhes</h1>

<div>
    <h4>Paciente</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nome)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nome)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Rg)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Rg)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Cpf)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Cpf)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DataNascimento)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DataNascimento)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.NomeResponsavel)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NomeResponsavel)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Sexo)
        </dt>
        <dd class="col-sm-10">
            @switch (Model.Sexo?.ToString())
            {
                case "F":
                    <span>Feminino</span>
                    break;
                case "M":

                    <span>Masculino</span>
                    break;
                case "O":

                    <span>Outros</span>
                    break;
                default:

                    <span>Não Informado</span>
                    break;
            }
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Etnia)
        </dt>
        <dd class="col-sm-10">
            @switch (Model.Etnia.ToString())
            {
                case "1":
                    <span>Pardo</span>
                    break;
                case "2":

                    <span>Preto</span>
                    break;
                case "3":

                    <span>Branco</span>
                    break;
                case "4":

                    <span>Amarelo</span>
                    break;
                case "5":

                    <span>Outro</span>
                    break;
                default:

                    <span>Não Informado</span>
                    break;
            }
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Endereco)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Endereco)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Bairro)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Bairro)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.TelResidencial)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TelResidencial)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.TelComercial)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TelComercial)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.TelCelular)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TelCelular)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Profissao)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Profissao)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.FlgAtleta)
        </dt>
        <dd class="col-sm-10">
            @(Model.FlgAtleta == true ? "Sim" : Model.FlgAtleta == false ? "Não" : "Não Informado")
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.FlgGestante)
        </dt>
        <dd class="col-sm-10">
            @(Model.FlgGestante == true ? "Sim" : Model.FlgGestante == false ? "Não" : "Não Informado")
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IdCidadeNavigation)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IdCidadeNavigation.Nome)
        </dd>
    </dl>
</div>
<div class="d-flex gap-2 mt-4">
    <a asp-action="Edit" class="btn btn-primary" asp-route-id="@Model?.IdPaciente">
        <i class="bi bi-pencil-square"></i> Editar
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left-short"></i> Voltar Lista de Pacientes
    </a>
</div>
